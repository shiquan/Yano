#!/usr/bin/env sh
# Clean generated files for source package distribution
rm -f src/Makevars src/Makevars.tmp src/*.o src/*.so src/*.dylib src/symbols.rds
# Clean htslib build artifacts
rm -f src/htslib-1.10.2/config.h src/htslib-1.10.2/config_vars.h src/htslib-1.10.2/config.mk
rm -f src/htslib-1.10.2/htscodecs.mk src/htslib-1.10.2/*.o src/htslib-1.10.2/*.a
rm -f src/htslib-1.10.2/*.so src/htslib-1.10.2/*.dylib src/htslib-1.10.2/hts-object-files
if [ -f src/htslib-1.10.2/Makefile ]; then
  (cd src/htslib-1.10.2 && make clean 2>/dev/null) || true
fi
